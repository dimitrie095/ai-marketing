# Database - MongoDB Atlas
# Example: mongodb+srv://username:password@cluster0.mongodb.net/marketing_ai?retryWrites=true&w=majority
MONGODB_URL=mongodb://localhost:27017/marketing_ai
DATABASE_NAME=marketing_ai

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Meta Ads API
META_ACCESS_TOKEN=your_meta_access_token_here
META_APP_ID=your_meta_app_id
META_AD_ACCOUNT_ID=your_ad_account_id

# LLM Providers (optional für Phase 1)
OPENAI_API_KEY=your_openai_key
KIMI_API_KEY=your_kimi_key
DEEPSEEK_API_KEY=your_deepseek_key

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_STR=/api/v1
